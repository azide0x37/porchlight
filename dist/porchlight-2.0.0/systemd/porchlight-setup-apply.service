[Unit]
Description=Apply allowlisted Porchlight setup requests
Documentation=file:/opt/porchlight/current/README.md

[Service]
Type=oneshot
EnvironmentFile=-/etc/porchlight/porchlight.env
ExecStart=/opt/porchlight/current/bin/setup-apply.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/porchlight /etc/porchlight
