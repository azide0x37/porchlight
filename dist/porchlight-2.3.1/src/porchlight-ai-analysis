#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path


SCRIPT = Path(__file__).resolve()
sys.path.insert(0, str(SCRIPT.parents[1] / "src"))
sys.path.insert(0, str(SCRIPT.parent))

from porchlight.ai_analysis import run_ai_analysis
from porchlight.config import load_config


def main() -> int:
    parser = argparse.ArgumentParser(prog="porchlight-ai-analysis")
    parser.add_argument("--apply", action="store_true")
    args = parser.parse_args()
    run_ai_analysis(load_config(apply=args.apply))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
