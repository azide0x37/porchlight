[Unit]
Description=Generate Porchlight AI analysis from rendered snapshots
Documentation=file:/opt/porchlight/current/README.md
After=network-online.target local-fs.target porchlight-render.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/porchlight/porchlight.env
EnvironmentFile=-/etc/porchlight/porchlight.openai.env
ExecStart=/opt/porchlight/current/bin/porchlight-ai-analysis --apply
TimeoutStartSec=3min
RuntimeDirectory=porchlight muster
RuntimeDirectoryPreserve=yes
StateDirectory=porchlight
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/porchlight /run/muster /var/lib/porchlight
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
