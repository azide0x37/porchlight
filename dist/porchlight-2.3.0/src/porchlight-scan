#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path


SCRIPT = Path(__file__).resolve()
sys.path.insert(0, str(SCRIPT.parents[1] / "src"))
sys.path.insert(0, str(SCRIPT.parent))

from porchlight.config import load_config
from porchlight.render import render
from porchlight.scan import collect_observations
from porchlight.service_types import service_counts
from porchlight.store import Store
from porchlight.util import append_event, now_iso, read_json, write_json


def parse_args():
    parser = argparse.ArgumentParser(
        prog="porchlight-scan",
        description="Build Porchlight LAN and Tailscale host snapshots.",
    )
    parser.add_argument("--apply", action="store_true", help="Use appliance paths instead of a mock root")
    parser.add_argument("--mode", choices=["discover", "scan", "deep"], default="scan")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    config = load_config(apply=args.apply)
    started = now_iso()
    store = Store(config.db_path, config.events_path)
    run_id = store.start_run(args.mode, started)
    error = None
    try:
        context, hosts, services, meta = collect_observations(config, args.mode)
        for host in hosts:
            store.upsert_host(host, started)
        for service in services:
            store.upsert_service(service, started)
        irregularities = store.record_run_snapshot(run_id, args.mode, hosts, services, started)
        active_hosts = [host for host in hosts if host.get("active")]
        counts = service_counts(services)
        new_hosts = sum(1 for item in irregularities if item["kind"] == "host_new")
        changed_services = sum(1 for item in irregularities if item["kind"].startswith("service_"))
        status = {
            "health": "healthy" if not meta.get("scan_blocked") else "degraded",
            "scan_state": "idle",
            "last_scan": started,
            "network_cidr": context["network_cidr"],
            "gateway": context["gateway"],
            "hosts_seen": len(hosts),
            "active_hosts": len(active_hosts),
            "open_ports": len(services),
            **counts,
            "new_hosts": new_hosts,
            "changed_services": changed_services,
            "changes_detected": "ON" if irregularities else "OFF",
            "scanner_online": True,
            "degraded": bool(meta.get("scan_blocked")),
            "scan_blocked": meta.get("scan_blocked"),
            "sources": meta["sources"],
        }
        if args.mode == "discover":
            previous_status = read_json(config.state_dir / "status.json")
            for key in (
                "open_ports",
                "http_services",
                "rtsp_services",
                "mqtt_services",
                "internal_services",
                "new_hosts",
                "changed_services",
                "changes_detected",
            ):
                if key in previous_status:
                    status[key] = previous_status[key]
        write_json(config.state_dir / "status.json", status)
        write_json(config.muster_state_dir / "status.json", {"health": status["health"], "scanner_online": True, "updated_at": started})
        render(config, store)
        append_event(
            config.events_path,
            {
                "event": "scan_completed",
                "at": started,
                "mode": args.mode,
                "hosts_seen": len(hosts),
                "open_ports": status["open_ports"],
                "irregularities": len(irregularities),
            },
        )
        store.finish_run(run_id, now_iso(), "completed", meta["targets_count"], len(hosts), len(services))
        return 0
    except Exception as exc:
        error = str(exc)
        append_event(config.events_path, {"event": "scan_failed", "at": now_iso(), "mode": args.mode, "error": error})
        store.finish_run(run_id, now_iso(), "failed", 0, 0, 0, error)
        raise


if __name__ == "__main__":
    raise SystemExit(main())
