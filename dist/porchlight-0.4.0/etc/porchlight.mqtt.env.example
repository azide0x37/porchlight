# Enable real broker publishing after reviewing the generated outbox files.
HA_MQTT_ENABLE=0

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_PUBLISH_TIMEOUT_SECONDS=5
MOSQUITTO_PUB=mosquitto_pub

HA_DISCOVERY_PREFIX=homeassistant
HA_NODE_ID=porchlight
HA_DEVICE_NAME=Porchlight LAN Directory
HA_BASE_TOPIC=porchlight

PORCHLIGHT_STATE_DIR=/run/porchlight
MUSTER_STATE_DIR=/run/muster
PORCHLIGHT_WWW_DIR=/var/lib/porchlight/www
HA_BRIDGE_RUNTIME_DIR=/run/muster/home-assistant-mqtt-bridge
HA_BRIDGE_STATE_DIR=/var/lib/muster/home-assistant-mqtt-bridge
