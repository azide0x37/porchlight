#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path


SCRIPT = Path(__file__).resolve()
sys.path.insert(0, str(SCRIPT.parents[1] / "src"))
sys.path.insert(0, str(SCRIPT.parent))

from porchlight.config import load_config
from porchlight.health import health


def main() -> int:
    parser = argparse.ArgumentParser(prog="porchlight-health")
    parser.add_argument("--apply", action="store_true")
    args = parser.parse_args()
    payload = health(load_config(apply=args.apply))
    print(payload["health"])
    return 0 if payload["health"] in {"healthy", "degraded"} else 1


if __name__ == "__main__":
    raise SystemExit(main())
