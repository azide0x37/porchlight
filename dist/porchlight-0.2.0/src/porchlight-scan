#!/usr/bin/env python3
import argparse
import ipaddress
import json
import os
import subprocess
from datetime import datetime, timezone
from pathlib import Path


PROJECT = "porchlight"


def parse_args():
    parser = argparse.ArgumentParser(
        prog="porchlight-scan",
        description="Build Porchlight LAN and Tailscale host snapshots.",
    )
    parser.add_argument("--apply", action="store_true", help="Use appliance paths instead of a mock root")
    parser.add_argument("--mode", choices=["discover", "scan", "deep"], default="scan")
    return parser.parse_args()


def run_json(command):
    try:
        result = subprocess.run(command, check=True, text=True, capture_output=True, timeout=20)
    except (FileNotFoundError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return None


def now_iso():
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def write_json(path, data):
    Path(path).parent.mkdir(parents=True, exist_ok=True)
    Path(path).write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def primary_tailscale_ip(peer):
    for ip in peer.get("TailscaleIPs") or []:
        if isinstance(ip, str) and ip.startswith("100."):
            return ip
    ips = peer.get("TailscaleIPs") or []
    return ips[0] if ips else None


def network_context():
    routes = run_json(["ip", "-j", "route", "show", "default"]) or []
    addrs = run_json(["ip", "-j", "addr", "show"]) or []
    route = routes[0] if routes else {}
    interface = route.get("dev")
    gateway = route.get("gateway", "unknown")
    cidr = "unknown"

    for iface in addrs:
        if iface.get("ifname") != interface:
            continue
        for addr in iface.get("addr_info", []):
            if addr.get("family") != "inet":
                continue
            local = addr.get("local")
            prefix = addr.get("prefixlen")
            if local and prefix is not None:
                cidr = str(ipaddress.ip_network(f"{local}/{prefix}", strict=False))
                break
    return {"interface": interface or "unknown", "gateway": gateway, "network_cidr": cidr}


def lan_hosts():
    rows = run_json(["ip", "-j", "neigh", "show"]) or []
    hosts = []
    for row in rows:
        ip = row.get("dst")
        states = row.get("state") or []
        if not ip or ":" in ip:
            continue
        state = states[0] if states else "UNKNOWN"
        if state in {"FAILED", "INCOMPLETE"}:
            active = False
        else:
            active = bool(row.get("lladdr"))
        hosts.append(
            {
                "ip": ip,
                "mac": row.get("lladdr"),
                "interface": row.get("dev"),
                "state": state,
                "active": active,
                "source": "lan-neighbor",
            }
        )
    return hosts


def tailscale_hosts():
    status = run_json(["tailscale", "status", "--json"])
    if not isinstance(status, dict):
        return []

    hosts = []
    self_peer = status.get("Self")
    if isinstance(self_peer, dict):
        hosts.append(tailscale_host(self_peer, self_node=True))

    peers = status.get("Peer") or {}
    for peer in peers.values():
        if isinstance(peer, dict):
            hosts.append(tailscale_host(peer, self_node=False))
    return [host for host in hosts if host.get("ip")]


def tailscale_host(peer, self_node):
    dns_name = peer.get("DNSName") or ""
    name = peer.get("HostName") or dns_name.rstrip(".") or "unknown"
    return {
        "ip": primary_tailscale_ip(peer),
        "tailscale_ips": peer.get("TailscaleIPs") or [],
        "hostname": name,
        "dns_name": dns_name.rstrip("."),
        "os": peer.get("OS"),
        "online": bool(peer.get("Online")),
        "active": bool(peer.get("Online")),
        "self": self_node,
        "last_seen": peer.get("LastSeen"),
        "source": "tailscale",
    }


def merge_hosts(host_lists):
    merged = {}
    for host_list in host_lists:
        for host in host_list:
            key = host.get("ip")
            if not key:
                continue
            existing = merged.setdefault(key, {"ip": key, "sources": []})
            source = host.get("source")
            if source and source not in existing["sources"]:
                existing["sources"].append(source)
            for field, value in host.items():
                if field in {"source"}:
                    continue
                if value not in (None, "", []):
                    existing[field] = value
            existing["active"] = bool(existing.get("active")) or bool(host.get("active"))
    return sorted(merged.values(), key=lambda item: ipaddress.ip_address(item["ip"]))


def load_previous(path):
    try:
        data = json.loads(Path(path).read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError):
        return set()
    return {host.get("ip") for host in data.get("hosts", []) if host.get("ip")}


def main():
    args = parse_args()
    if args.apply:
        state_dir = Path(os.environ.get("PORCHLIGHT_STATE_DIR", "/run/porchlight"))
        muster_state_dir = Path(os.environ.get("MUSTER_STATE_DIR", "/run/muster"))
        www_dir = Path(os.environ.get("PORCHLIGHT_WWW_DIR", "/var/lib/porchlight/www"))
        data_dir = Path(os.environ.get("PORCHLIGHT_DATA_DIR", "/var/lib/porchlight"))
    else:
        root = Path(os.environ.get("PORCHLIGHT_MOCK_ROOT") or os.environ.get("MUSTER_MOCK_ROOT") or f"{os.environ.get('TMPDIR', '/tmp')}/porchlight-mock")
        state_dir = root / "run/porchlight"
        muster_state_dir = root / "run/muster"
        www_dir = root / "var/lib/porchlight/www"
        data_dir = root / "var/lib/porchlight"

    context = network_context()
    lan = lan_hosts()
    tailscale = tailscale_hosts()
    hosts = merge_hosts([lan, tailscale])
    previous_hosts = load_previous(data_dir / "hosts.json")
    current_hosts = {host["ip"] for host in hosts}
    new_hosts = sorted(current_hosts - previous_hosts, key=ipaddress.ip_address)
    active_hosts = [host for host in hosts if host.get("active")]
    ts = now_iso()

    inventory = {
        "generated_at": ts,
        "mode": args.mode,
        "network": context,
        "hosts": hosts,
        "sources": {
            "lan_neighbor_count": len(lan),
            "tailscale_count": len(tailscale),
        },
    }
    status = {
        "health": "healthy",
        "scan_state": "idle",
        "last_scan": ts,
        "network_cidr": context["network_cidr"],
        "gateway": context["gateway"],
        "hosts_seen": len(hosts),
        "active_hosts": len(active_hosts),
        "open_ports": 0,
        "new_hosts": len(new_hosts),
        "changed_services": 0,
        "changes_detected": "ON" if new_hosts else "OFF",
        "scanner_online": True,
        "degraded": False,
        "sources": inventory["sources"],
    }

    write_json(data_dir / "hosts.json", inventory)
    write_json(state_dir / "status.json", status)
    write_json(muster_state_dir / "status.json", {"health": "healthy", "scanner_online": True, "updated_at": ts})
    write_json(www_dir / "hosts.json", inventory)
    write_json(www_dir / "status.json", status)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
