PORCHLIGHT_STATE_DIR=/run/porchlight
MUSTER_STATE_DIR=/run/muster
PORCHLIGHT_DATA_DIR=/var/lib/porchlight
PORCHLIGHT_WWW_DIR=/var/lib/porchlight/www
PORCHLIGHT_CONFIG_DIR=/etc/porchlight
PORCHLIGHT_ENABLED=1
PORCHLIGHT_ALLOWED_INTERFACES=wlan0,eth0
PORCHLIGHT_ALLOWED_CIDRS=auto
PORCHLIGHT_MAX_PREFIX=24
PORCHLIGHT_PRIVATE_ONLY=true
PORCHLIGHT_SCAN_GATEWAY=true
PORCHLIGHT_SCAN_TAILSCALE=false
PORCHLIGHT_FULL_TCP_SCAN=false
PORCHLIGHT_DEEP_SCAN_INTERVAL=weekly
PORCHLIGHT_VERSION_PROBE=true
PORCHLIGHT_NSE_SCRIPTS=false
PORCHLIGHT_UDP_SCAN=false
PORCHLIGHT_NMAP_HOST_TIMEOUT=90s
PORCHLIGHT_HTTP_TITLE_TIMEOUT_SECONDS=2.5
PORCHLIGHT_COMMON_PORTS=22,53,80,81,139,443,445,548,554,631,1883,3000,3389,5000,5357,5900,8000,8008,8080,8081,8123,8443,8554,8883,9000,9100,32400
